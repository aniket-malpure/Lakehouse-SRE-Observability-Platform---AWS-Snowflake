{
  "title": "Lakehouse SRE — Pipeline Observability",
  "uid": "lakehouse-sre",
  "tags": ["sre", "snowflake", "lakehouse", "slo"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },

  "templating": {
    "list": [
      {
        "name": "pipeline",
        "type": "query",
        "label": "Pipeline",
        "datasource": "Prometheus",
        "query": "label_values(snowflake_pipeline_duration_seconds_count, pipeline_name)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "title": "SLO Compliance — Error Rate (1h rolling)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green",  "value": 0.999 }
            ]
          },
          "mappings": [],
          "min": 0, "max": 1
        }
      },
      "targets": [
        {
          "expr": "avg(snowflake_slo_compliance_ratio{pipeline_name=~\"$pipeline\"})",
          "legendFormat": "Compliance",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      }
    },

    {
      "id": 2,
      "title": "Burn Rate — 1h Window",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0, "max": 20,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 6 },
              { "color": "red",    "value": 14.4 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "max(rate(snowflake_pipeline_errors_total{pipeline_name=~\"$pipeline\"}[1h]) / (rate(snowflake_pipeline_errors_total{pipeline_name=~\"$pipeline\"}[1h]) + rate(snowflake_pipeline_rows_processed{pipeline_name=~\"$pipeline\"}[1h]) + 0.001) / 0.01)",
          "legendFormat": "Burn Rate",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdMarkers": true
      }
    },

    {
      "id": 3,
      "title": "Pipeline p95 Latency (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 240 },
              { "color": "red",    "value": 300 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (pipeline_name, le) (rate(snowflake_pipeline_duration_seconds_bucket{status=\"SUCCESS\", pipeline_name=~\"$pipeline\"}[5m])))",
          "legendFormat": "{{pipeline_name}} p95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (pipeline_name, le) (rate(snowflake_pipeline_duration_seconds_bucket{status=\"SUCCESS\", pipeline_name=~\"$pipeline\"}[5m])))",
          "legendFormat": "{{pipeline_name}} p50",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },

    {
      "id": 4,
      "title": "Data Freshness — Minutes Since Last Load",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red",    "value": 30 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "snowflake_data_freshness_minutes{pipeline_name=~\"$pipeline\"}",
          "legendFormat": "{{pipeline_name}} — {{target_table}}",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },

    {
      "id": 5,
      "title": "Pipeline Error Rate (per minute)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "errors/min",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "rate(snowflake_pipeline_errors_total{pipeline_name=~\"$pipeline\"}[5m]) * 60",
          "legendFormat": "{{pipeline_name}} — {{error_type}}",
          "datasource": "Prometheus"
        }
      ]
    },

    {
      "id": 6,
      "title": "Snowflake Credits Consumed (per pipeline)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "displayName": "${__field.labels.pipeline_name}"
        }
      },
      "targets": [
        {
          "expr": "snowflake_pipeline_credits_used{pipeline_name=~\"$pipeline\"}",
          "legendFormat": "{{pipeline_name}} ({{warehouse}})",
          "datasource": "Prometheus"
        }
      ]
    },

    {
      "id": 7,
      "title": "Warehouse Utilization %",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red",    "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "snowflake_warehouse_utilization_pct",
          "legendFormat": "{{warehouse_name}}",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdMarkers": true
      }
    },

    {
      "id": 8,
      "title": "Rows Processed per Pipeline Run",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "snowflake_pipeline_rows_processed{pipeline_name=~\"$pipeline\"}",
          "legendFormat": "{{pipeline_name}}",
          "datasource": "Prometheus"
        }
      ]
    },

    {
      "id": 9,
      "title": "Active Firing Alerts",
      "type": "alertlist",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 5 },
      "options": {
        "alertName": "",
        "dashboardAlerts": false,
        "groupMode": "default",
        "groupBy": ["alertname", "pipeline_name"],
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": {
          "firing": true,
          "pending": true,
          "noData": false,
          "error": true,
          "normal": false
        }
      }
    }

  ]
}
